# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# --- Environnements virtuels ---
.venv/
venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Tests / couverture ---
.pytest_cache/
.coverage
htmlcov/
